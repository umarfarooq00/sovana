    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "Heading",
      "default": "Style that speaks for itself."
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "Subheading",
      "default": "Discover our latest collection and find pieces that were made exactly for you.",
      "info": "Leave empty to hide"
    },
    {
      "type": "header",
      "content": "CTA Colors"
    },
    {
      "type": "range",
      "id": "cta_title_size",
      "label": "Heading size (desktop)",
      "min": 28,
