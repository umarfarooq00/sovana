<style>
  .about-values-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.section_padding }}px 60px;
    text-align: center;
  }

  .about-values-{{ section.id }} .values__head {
    margin-bottom: {{ section.settings.head_spacing }}px;
  }

  .about-values-{{ section.id }} .values__eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: 16px;
    display: block;
  }

  .about-values-{{ section.id }} .values__title {
    font-family: "Gilda Display", serif;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .about-values-{{ section.id }} .values__subtitle {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    color: {{ section.settings.subtitle_color }};
    max-width: 520px;
    margin: 0 auto;
    opacity: 0.75;
  }

  .about-values-{{ section.id }} .values__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.card_gap }}px;
    max-width: {{ section.settings.grid_max_width }}px;
    margin: 0 auto;
  }

  .about-values-{{ section.id }} .values__card {
    padding: {{ section.settings.card_padding }}px 24px;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    transition: border-color 0.3s ease;
  }

  .about-values-{{ section.id }} .values__card:hover {
    border-color: {{ section.settings.eyebrow_color }};
  }

  .about-values-{{ section.id }} .values__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin: 0 auto {{ section.settings.icon_spacing }}px;
    color: {{ section.settings.icon_color }};
    display: block;
  }

  .about-values-{{ section.id }} .values__card-title {
    font-family: "Gilda Display", serif;
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 700;
    color: {{ section.settings.card_title_color }};
    margin-bottom: 10px;
  }

  .about-values-{{ section.id }} .values__card-text {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.7;
    color: {{ section.settings.card_text_color }};
  }

  @media (max-width: 767px) {
    .about-values-{{ section.id }} {
      padding: 60px 24px;
    }
    .about-values-{{ section.id }} .values__grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .about-values-{{ section.id }} .values__title {
      font-size: {{ section.settings.title_size | times: 0.7 | round }}px;
    }
  }

  @media (max-width: 480px) {
    .about-values-{{ section.id }} .values__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="about-values-{{ section.id }}">

  <div class="values__head">
    {% if section.settings.eyebrow != blank %}
      <span class="values__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="values__title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="values__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="values__grid">
    {% for block in section.blocks %}
      <div class="values__card" {{ block.shopify_attributes }}>
        {% if block.settings.icon != 'none' %}
          <svg class="values__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'shield' %}
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              {% when 'clock' %}
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              {% when 'heart' %}
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/>
              {% when 'star' %}
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              {% when 'leaf' %}
                <path d="M17 8C8 10 5.9 16.17 3.82 19.34A1 1 0 0 0 4.62 21c7.43-.45 12.46-5.3 13.38-13"/>
                <path d="M3 3c10 3 11 12 11 17"/>
              {% when 'globe' %}
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              {% when 'sun' %}
                <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              {% when 'award' %}
                <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
            {% endcase %}
          </svg>
        {% endif %}
        {% if block.settings.title != blank %}
          <div class="values__card-title">{{ block.settings.title }}</div>
        {% endif %}
        {% if block.settings.text != blank %}
          <p class="values__card-text">{{ block.settings.text }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>

</section>

{% schema %}
{
  "name": "About — Values",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#2a2018"
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding (top & bottom)",
      "min": 40,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What we stand for"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our values"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading",
      "info": "Leave empty to hide"
    },
    {
      "type": "range",
      "id": "head_spacing",
      "label": "Space below heading",
      "min": 24,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "grid_max_width",
      "label": "Grid max width",
      "min": 600,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding (top & bottom)",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#3d3020"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Space below icon",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#c9a96e"
    },
    {
      "type": "header",
      "content": "Typography Colors"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Heading size (desktop)",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Card title size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subheading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#8a7a6a"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none",   "label": "None" },
            { "value": "shield", "label": "Shield" },
            { "value": "clock",  "label": "Clock" },
            { "value": "heart",  "label": "Heart" },
            { "value": "star",   "label": "Star" },
            { "value": "leaf",   "label": "Leaf" },
            { "value": "globe",  "label": "Globe" },
            { "value": "sun",    "label": "Sun" },
            { "value": "award",  "label": "Award" }
          ],
          "default": "heart"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Our Value"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "A short description of this value and what it means to us."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About — Values",
      "blocks": [
        { "type": "value", "settings": { "icon": "shield", "title": "Quality First",    "text": "Every piece is made to last. We never compromise on fabric, finish, or fit." } },
        { "type": "value", "settings": { "icon": "clock",  "title": "Timeless Design",  "text": "No fast fashion. We design pieces that transcend seasons and trends." } },
        { "type": "value", "settings": { "icon": "heart",  "title": "Made with Care",   "text": "From sourcing to delivery, every step is handled with intention and love." } },
        { "type": "value", "settings": { "icon": "sun",    "title": "Woman-Led",         "text": "Designed by women, for women. We understand how you want to feel." } }
      ]
    }
  ]
}
{% endschema %}
