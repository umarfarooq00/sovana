      "id": "btn_bg_color",
      "label": "Button color",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "btn_radius",
