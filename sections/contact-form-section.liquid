      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "info_title_color",
      "label": "Info heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "info_text_color",
      "label": "Info text color",
      "default": "#5a5a5a"
    },
    {
      "type": "header",
      "content": "Contact Details"
    },
    {
