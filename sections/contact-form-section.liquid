    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form heading",
      "default": "Send us a message",
      "info": "Leave empty to hide"
    },
    {
      "type": "text",
      "id": "form_subtitle",
      "label": "Form subheading",
      "default": "Fill in the form below and we'll get back to you shortly.",
      "info": "Leave empty to hide"
    },
    {
      "type": "range",
      "id": "form_title_size",
      "label": "Form heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "form_title_color",
      "label": "Form heading color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Input Fields"
    },
    {
      "type": "color",
      "id": "input_bg_color",
