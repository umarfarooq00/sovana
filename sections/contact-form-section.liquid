      "default": "Mon–Fri, 9am–6pm",
      "info": "Leave empty to hide"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "3701 North Country Club Drive, Aventura, Florida 33180",
      "info": "Leave empty to hide"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Response time",
      "default": "We reply within 24 hours",
      "info": "Leave empty to hide"
    },
    {
      "type": "header",
      "content": "Form Box"
    },
    {
      "type": "color",
      "id": "form_bg_color",
      "label": "Form background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "form_padding",
      "label": "Form padding",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "form_radius",
      "label": "Form border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_form_border",
