

<style>

  /* ─────────────────────────────────────────
     RESET & BASE
  ───────────────────────────────────────── */
  .footer-{{ section.id }} *,
  .footer-{{ section.id }} *::before,
  .footer-{{ section.id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .footer-{{ section.id }} a {
    text-decoration: none;
    color: inherit;
  }

  /* ─────────────────────────────────────────
     FOOTER WRAPPER
  ───────────────────────────────────────── */
  .footer-{{ section.id }} {
    background-color: {{ section.settings.footer_bg_color }};
    width: 100%;
  }

  /* ─────────────────────────────────────────
     1. NEWSLETTER BAR
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__newsletter {
    background-color: {{ section.settings.newsletter_bg_color }};
    padding: 20px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer__newsletter-text-wrap {}

  .footer-{{ section.id }} .footer__newsletter-heading {
    font-family: 'Elegant';
    font-size: {{ section.settings.newsletter_heading_size }}px;
    font-weight: 700;
    color: {{ section.settings.newsletter_heading_color }};
    line-height: 1.2;
  }

  .footer-{{ section.id }} .footer__newsletter-subtext {
    font-size: 13px;
    font-weight: 300;
    color: {{ section.settings.newsletter_subtext_color }};
    margin-top: 4px;
    opacity: 0.85;
  }

  .footer-{{ section.id }} .footer__newsletter-form {
    display: flex;
    gap: 8px;
    flex: 1;
    max-width: 420px;
  }

  .footer-{{ section.id }} .footer__newsletter-input {
    flex: 1;
    height: 44px;
    background: {{ section.settings.newsletter_input_bg }};
    border: 1px solid {{ section.settings.newsletter_input_border }};
    border-radius: {{ section.settings.btn_radius }}px;
    padding: 0 16px;
    font-size: 13px;
    color: {{ section.settings.newsletter_input_text }};
    outline: none;
    transition: border-color 0.2s;
  }

  .footer-{{ section.id }} .footer__newsletter-input::placeholder {
    color: {{ section.settings.newsletter_input_placeholder }};
  }

  .footer-{{ section.id }} .footer__newsletter-input:focus {
    border-color: {{ section.settings.newsletter_btn_bg }};
  }

  .footer-{{ section.id }} .footer__newsletter-btn {
    height: 44px;
    padding: 0 24px;
    background-color: {{ section.settings.newsletter_btn_bg }};
    color: {{ section.settings.newsletter_btn_text }};
    border: 2px solid {{ section.settings.newsletter_btn_bg }};
    border-radius: {{ section.settings.btn_radius }}px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .footer-{{ section.id }} .footer__newsletter-btn:hover {
    background-color: transparent;
    color: {{ section.settings.newsletter_btn_bg }};
  }

  /* ─────────────────────────────────────────
     2. MAIN GRID
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__main {
    padding: {{ section.settings.footer_padding_top }}px 40px {{ section.settings.footer_padding_bottom }}px;
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr 1fr; 
    gap: 40px;
  }

  /* ─────────────────────────────────────────
     3. BRAND COLUMN
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__brand-logo-img {
    max-width: {{ section.settings.logo_max_width }}px;
    height: auto;
    display: block;
    margin-bottom: 16px;
  }

  .footer-{{ section.id }} .footer__brand-logo-text {
    font-family: 'Elegant';
    font-size: {{ section.settings.logo_text_size }}px;
    font-weight: 700;
    color: {{ section.settings.logo_text_color }};
    letter-spacing: 0.06em;
    margin-bottom: 16px;
    display: block;
  }

  .footer-{{ section.id }} .footer__brand-desc {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.75;
    color: {{ section.settings.brand_desc_color }};
    margin-bottom: 24px;
  }

  /* Social icons */
  .footer-{{ section.id }} .footer__socials {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer__social-link {
    width: 36px;
    height: 36px;
    border: 1px solid {{ section.settings.social_border_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .footer-{{ section.id }} .footer__social-link:hover {
    background-color: {{ section.settings.social_hover_bg }};
    border-color: {{ section.settings.social_hover_bg }};
  }

  .footer-{{ section.id }} .footer__social-link svg {
    width: 15px;
    height: 15px;
    fill: {{ section.settings.social_icon_color }};
    transition: fill 0.2s ease;
  }

  .footer-{{ section.id }} .footer__social-link:hover svg {
    fill: {{ section.settings.social_hover_icon_color }};
  }

  /* ─────────────────────────────────────────
     4. LINK COLUMNS
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__col-title {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.col_title_color }};
    margin-bottom: 18px;
    display: block;
  }

  .footer-{{ section.id }} .footer__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-{{ section.id }} .footer__links li a {
    font-size: 13px;
    font-weight: 300;
    color: {{ section.settings.link_color }};
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .footer-{{ section.id }} .footer__links li a:hover {
    color: {{ section.settings.link_hover_color }};
  }

  /* ─────────────────────────────────────────
     5. CONTACT COLUMN
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 14px;
  }

  .footer-{{ section.id }} .footer__contact-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-{{ section.id }} .footer__contact-icon svg {
    width: 16px;
    height: 16px;
    fill: {{ section.settings.contact_icon_color }};
  }

  .footer-{{ section.id }} .footer__contact-text {
    font-size: 13px;
    font-weight: 300;
    line-height: 1.65;
    color: {{ section.settings.link_color }};
  }

  .footer-{{ section.id }} .footer__contact-text a {
    color: {{ section.settings.link_color }};
    transition: color 0.2s;
  }

  .footer-{{ section.id }} .footer__contact-text a:hover {
    color: {{ section.settings.link_hover_color }};
  }

  /* ─────────────────────────────────────────
     6. DIVIDER
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__divider {
    height: 1px;
    background-color: {{ section.settings.divider_color }};
    margin: 0 40px;
    opacity: 0.15;
  }

  /* ─────────────────────────────────────────
     7. BOTTOM BAR
  ───────────────────────────────────────── */
  .footer-{{ section.id }} .footer__bottom {
    padding: 18px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer__copyright {
    font-size: 12px;
    color: {{ section.settings.copyright_color }};
    opacity: 0.5;
  }

  /* Payment icons */
  .footer-{{ section.id }} .footer__payment-icons {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer__payment-icons img {
    height: 22px;
    width: auto;
    opacity: 0.6;
    filter: grayscale(30%);
  }

  /* Policy links */
  .footer-{{ section.id }} .footer__policy-links {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer-{{ section.id }} .footer__policy-links a {
    font-size: 12px;
    color: {{ section.settings.copyright_color }};
    opacity: 0.45;
    transition: opacity 0.2s;
  }

  .footer-{{ section.id }} .footer__policy-links a:hover {
    opacity: 1;
    color: {{ section.settings.link_hover_color }};
  }

  /* ─────────────────────────────────────────
     RESPONSIVE — TABLET (768px)
  ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .footer-{{ section.id }} .footer__main {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      padding-left: 24px;
      padding-right: 24px;
    }
    .footer-{{ section.id }} .footer__newsletter {
      padding: 20px 24px;
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-{{ section.id }} .footer__newsletter-form {
      max-width: 100%;
      width: 100%;
    }
    .footer-{{ section.id }} .footer__divider {
      margin: 0 24px;
    }
    .footer-{{ section.id }} .footer__bottom {
      padding: 16px 24px;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  /* ─────────────────────────────────────────
     RESPONSIVE — MOBILE (480px)
  ───────────────────────────────────────── */
  @media (max-width: 480px) {
    .footer-{{ section.id }} .footer__main {
      grid-template-columns: 1fr;
      gap: 28px;
      padding-left: 20px;
      padding-right: 20px;
    }
    .footer-{{ section.id }} .footer__newsletter {
      padding: 20px;
    }
    .footer-{{ section.id }} .footer__newsletter-form {
      flex-direction: column;
    }
    .footer-{{ section.id }} .footer__newsletter-btn {
      width: 100%;
    }
    .footer-{{ section.id }} .footer__newsletter-heading {
      font-size: {{ section.settings.newsletter_heading_size | times: 0.8 | round }}px;
    }
    .footer-{{ section.id }} .footer__divider {
      margin: 0 20px;
    }
    .footer-{{ section.id }} .footer__bottom {
      padding: 16px 20px;
    }
    .footer-{{ section.id }} .footer__policy-links {
      gap: 12px;
    }
  }

</style>

<footer class="footer-{{ section.id }}">

  {% comment %} ── 1. NEWSLETTER BAR ── {% endcomment %}
  {% if section.settings.show_newsletter %}
  <div class="footer__newsletter">
    <div class="footer__newsletter-text-wrap">
      {% if section.settings.newsletter_heading != blank %}
        <p class="footer__newsletter-heading">{{ section.settings.newsletter_heading }}</p>
      {% endif %}
      {% if section.settings.newsletter_subtext != blank %}
        <p class="footer__newsletter-subtext">{{ section.settings.newsletter_subtext }}</p>
      {% endif %}
    </div>

    {% form 'customer', id: 'footer-newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="footer__newsletter-form">
        <input
          class="footer__newsletter-input"
          type="email"
          name="contact[email]"
          id="footer-newsletter-email"
          placeholder="{{ section.settings.newsletter_placeholder }}"
          required
          autocorrect="off"
          autocapitalize="off"
        >
        <button type="submit" class="footer__newsletter-btn">
          {{ section.settings.newsletter_btn_label }}
        </button>
      </div>
    {% endform %}
  </div>
  {% endif %}

  {% comment %} ── 2. MAIN GRID ── {% endcomment %}
  <div class="footer__main">

    {% comment %} ── BRAND COLUMN ── {% endcomment %}
    <div class="footer__brand-col">

      {% if section.settings.logo != blank %}
        {{ section.settings.log | image_url: width: section.settings.log.width | image_tag: loading: 'lazy', class: 'footer__brand-logo-img' }}
      {% elsif section.settings.logo_text != blank %}
        <span class="footer__brand-logo-text">{{ section.settings.logo_text }}</span>
      {% else %}
        <span class="footer__brand-logo-text">{{ shop.name }}</span>
      {% endif %}

      {% if section.settings.brand_description != blank %}
        <p class="footer__brand-desc">{{ section.settings.brand_description }}</p>
      {% endif %}

      <div class="footer__socials">
        {% if section.settings.social_instagram != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_tiktok != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
            <svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.77 1.52V6.77a4.85 4.85 0 01-1-.08z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_twitter != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter / X">
            <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_pinterest != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
            <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_youtube != blank %}
          <a class="footer__social-link" href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {% endif %}
      </div>

    </div>

    {% comment %} ── SHOP COLUMN ── {% endcomment %}
    {% if section.settings.show_shop_col %}
    <div class="footer__shop-col">
      <span class="footer__col-title">{{ section.settings.shop_col_title }}</span>
      <ul class="footer__links">
        {% for link in section.settings.shop_menu.links %}
            <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% comment %} ── HELP COLUMN ── {% endcomment %}
    {% if section.settings.show_help_col %}
    <div class="footer__help-col">
      <span class="footer__col-title">{{ section.settings.help_col_title }}</span>
      <ul class="footer__links">
        {% for link in section.settings.help_menu.links %}
            <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if section.settings.show_policy_col %}
    <div class="footer__policy-col">
      <span class="footer__col-title">{{ section.settings.policy_col_title }}</span>
      <ul class="footer__links">
        {% for link in section.settings.policy_menu.links %}
            <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% comment %} ── CONTACT COLUMN ── {% endcomment %}
    {% if section.settings.show_contact_col %}
    <div class="footer__contact-col">
      <span class="footer__col-title">{{ section.settings.contact_col_title }}</span>

      {% if section.settings.contact_email != blank %}
        <div class="footer__contact-item">
          <div class="footer__contact-icon">
            <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <div class="footer__contact-text">
            <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
          </div>
        </div>
      {% endif %}

      {% if section.settings.contact_phone != blank %}
        <div class="footer__contact-item">
          <div class="footer__contact-icon">
            <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          </div>
          <div class="footer__contact-text">
            <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
          </div>
        </div>
      {% endif %}

      {% if section.settings.contact_hours != blank %}
        <div class="footer__contact-item">
          <div class="footer__contact-icon">
            <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
          </div>
          <div class="footer__contact-text">{{ section.settings.contact_hours }}</div>
        </div>
      {% endif %}

      {% if section.settings.contact_address != blank %}
        <div class="footer__contact-item">
          <div class="footer__contact-icon">
            <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <div class="footer__contact-text">{{ section.settings.contact_address }}</div>
        </div>
      {% endif %}

    </div>
    {% endif %}

  </div>

  {% comment %} ── DIVIDER ── {% endcomment %}
  <div class="footer__divider"></div>

  {% comment %} ── BOTTOM BAR ── {% endcomment %}
  <div class="footer__bottom">

    <p class="footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_name | default: shop.name }}. {{ section.settings.copyright_suffix }}
    </p>

    {% if section.settings.show_payment_icons %}
      <ul
        class="payment-icons__list"
        role="list"
      >
        {%- for type in shop.enabled_payment_types -%}
          <li class="payment-icons__item">
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          </li>
        {%- endfor -%}
      </ul>
    {% endif %}

