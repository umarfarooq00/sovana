{%- style -%}
  #marquee_main-{{ section.id }} {
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }
  #marquee_main-{{ section.id }} span {
    color: {{ section.settings.font_color }};
  }
{%- endstyle -%}
<section class="marquee_main" id="marquee_main-{{ section.id }}">
  <div class="container">
    <div class="marquee_inner">
      {% for block in section.blocks %}
        {% if block.settings.text != blank %}
          <span class="marquee_col">{{ block.settings.text }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    $('#marquee_main-{{ section.id }} .marquee_inner').slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      dots: false,
      autoplay: false,
      autoplaySpeed: 2000,
      arrows: true,
      fade: true,
      infinite: true
    });
  });
</script>
{% schema %}
  {
    "name": "Marquee",
    "settings": [
      {
        "type": "color",
        "id": "bg_color",
        "label": "BG Color",
        "default": "#C9A96E"
      },
      {
        "type": "color",
        "id": "font_color",
        "label": "Font Color",
        "default": "#ffffff"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Top",
        "default": 10
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding Bottom",
        "default": 10
      },
    ],
    "blocks": [
      {
        "name":"Add Text",
        "type":"add_text",
        "settings":[
          {
            "type": "text",
            "id": "text",
            "label": "Add Text",
            "default": "New Season Arrivals"
          }
        ]
      }
    ],
    "presets":[
      {
        "name":"Marquee",
        "blocks": [
          {
            "type": "add_text"
          },
          {
            "type": "add_text"
          },
          {
            "type": "add_text"
          },
          {
            "type": "add_text"
          }
        ]
      }
    ]
  }
{% endschema %}