
<style>
  .trust-strip-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    padding: {{ section.settings.padding }}px 40px;
  }

  .trust-strip-{{ section.id }} .trust__grid {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    max-width: 960px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .trust-strip-{{ section.id }} .trust__item {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1 1 200px;
    justify-content: center;
    padding: 12px 24px;
  }

  .trust-strip-{{ section.id }} .trust__item + .trust__item {
    border-left: 1px solid {{ section.settings.border_color }};
  }

  .trust-strip-{{ section.id }} .trust__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
    flex-shrink: 0;
  }

  .trust-strip-{{ section.id }} .trust__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-strip-{{ section.id }} .trust__label {
    font-family: "Gilda Display", serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: {{ section.settings.label_color }};
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .trust-strip-{{ section.id }} .trust__sublabel {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: {{ section.settings.sublabel_color }};
    opacity: 0.6;
  }

  @media (max-width: 749px) {
    .trust-strip-{{ section.id }} {
      padding: 20px 16px;
    }

    .trust-strip-{{ section.id }} .trust__grid {
      gap: 0;
    }

    .trust-strip-{{ section.id }} .trust__item {
      flex: 1 1 44%;
      padding: 16px 8px;
      gap: 10px;
    }

    .trust-strip-{{ section.id }} .trust__item + .trust__item:nth-child(odd) {
      border-left: none;
    }

    .trust-strip-{{ section.id }} .trust__item:nth-child(n+3) {
      border-top: 1px solid {{ section.settings.border_color }};
    }
  }
</style>

<div class="trust-strip-{{ section.id }}">
  <div class="trust__grid">
    {% for block in section.blocks %}
      <div class="trust__item" {{ block.shopify_attributes }}>
        {% if block.settings.icon != 'none' %}
          <svg class="trust__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {% case block.settings.icon %}
              {% when 'truck' %}
                <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              {% when 'return' %}
                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
              {% when 'shield' %}
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              {% when 'lock' %}
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              {% when 'gift' %}
                <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
              {% when 'star' %}
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            {% endcase %}
          </svg>
        {% endif %}
        <div class="trust__text">
          {% if block.settings.label != blank %}
            <span class="trust__label">{{ block.settings.label }}</span>
          {% endif %}
          {% if block.settings.sublabel != blank %}
            <span class="trust__sublabel">{{ block.settings.sublabel }}</span>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Product Trust Strip",
  "tag": "div",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#faf9f7"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border & divider color",
      "default": "#e8e3db"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding (top & bottom)",
      "min": 12,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "sublabel_color",
      "label": "Sublabel color",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none",   "label": "None" },
            { "value": "truck",  "label": "Shipping" },
            { "value": "return", "label": "Returns" },
            { "value": "shield", "label": "Shield" },
            { "value": "lock",   "label": "Secure" },
            { "value": "gift",   "label": "Gift" },
            { "value": "star",   "label": "Star" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label",
          "default": "Orders over $150"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Trust Strip",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck",  "label": "Free Shipping",     "sublabel": "Orders over $150" } },
        { "type": "item", "settings": { "icon": "return", "label": "Easy Returns",       "sublabel": "30-day return window" } },
        { "type": "item", "settings": { "icon": "shield", "label": "Quality Guaranteed", "sublabel": "Crafted to last" } },
        { "type": "item", "settings": { "icon": "lock",   "label": "Secure Checkout",    "sublabel": "SSL encrypted" } }
      ]
    }
  ]
}
{% endschema %}
